{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-streaming-lab.local/schemas/web_analytics_v1.json",
  "title": "Web Analytics Event",
  "description": "Version 1 contract for Tinybird Mockingbird Web Analytics Starter Kit events.",
  "type": "object",
  "additionalProperties": false,
  "x-schema-name": "web_analytics",
  "x-schema-version": "1",
  "required": [
    "timestamp",
    "session_id",
    "user_id",
    "page_url",
    "referrer"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Event timestamp generated by Mockingbird."
    },
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "page_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://example\\.com/"
    },
    "referrer": {
      "type": "string",
      "format": "uri"
    }
  }
}
